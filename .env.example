POSTGRES_USER=anvil
POSTGRES_PASSWORD=anvil
POSTGRES_DB=anvil
POSTGRES_PORT=5432

ANVIL_BEARER_TOKEN=dev-token-change-me
ANVIL_DATABASE_URL=postgresql+asyncpg://anvil:anvil@db:5432/anvil
ANVIL_RUNNER_SOCKET=/run/anvil/runner.sock
ANVIL_DATA_DIR=/var/lib/anvil
ANVIL_LOG_LEVEL=info
ANVIL_SIMULATION_MODE=false

ANVIL_HTTP_PORT=8080
ANVIL_WEB_PORT=8081
